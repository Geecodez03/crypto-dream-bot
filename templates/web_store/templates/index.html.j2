{% extends "base.html" %}

{% block title %}Home{% endblock %}

{% block content %}
<div class="text-center py-12">
    <h1 class="text-4xl font-bold text-gray-800 mb-4">Welcome to {{ project_name }}</h1>
    <p class="text-xl text-gray-600 mb-8">{{ project_description }}</p>
    
    <div class="bg-white rounded-lg shadow-md p-8 max-w-2xl mx-auto">
        <h2 class="text-2xl font-semibold mb-4">Getting Started</h2>
        <p class="text-gray-700 mb-6">
            This is your new web_store project. Customize it to fit your needs!
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-blue-50 p-4 rounded-lg">
                <i class="fas fa-rocket text-blue-500 text-2xl mb-2"></i>
                <h3 class="font-semibold">Fast Development</h3>
                <p class="text-sm">Built with modern frameworks</p>
            </div>
            <div class="bg-green-50 p-4 rounded-lg">
                <i class="fas fa-mobile-alt text-green-500 text-2xl mb-2"></i>
                <h3 class="font-semibold">Responsive Design</h3>
                <p class="text-sm">Works on all devices</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
